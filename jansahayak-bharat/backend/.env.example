# ===== Server =====
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.web.app

# ===== Firebase Admin (Firebase Console > Project Settings > Service Accounts > Generate new private key) =====
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-firebase-project.appspot.com

# ===== Gemini AI (https://aistudio.google.com/app/apikey) - REAL =====
GEMINI_API_KEY=your_gemini_api_key

# ===== OpenWeatherMap (https://openweathermap.org/api) - REAL, free tier =====
OPENWEATHER_API_KEY=your_openweather_api_key

# ===== NewsAPI (https://newsapi.org) - REAL, free tier for dev =====
NEWS_API_KEY=your_newsapi_key

# ===== data.gov.in Agmarknet Mandi Bhav API (https://data.gov.in) - REAL government API, free registration =====
DATA_GOV_IN_API_KEY=your_data_gov_in_api_key
DATA_GOV_IN_MANDI_RESOURCE_ID=9ef84268-d588-465a-a308-a864a43d0070

# ===== Google Maps (console.cloud.google.com - enable Maps JavaScript + Places API) - REAL =====
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ===== Admin =====
ADMIN_EMAILS=admin@jansahayak.in
